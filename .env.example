# =============================================================================
# TrustNAS Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# docker compose reads .env automatically.
# All variables below have defaults (shown in parentheses); uncomment to override.
#
# NOTE: If you change NGINX_GARAGE_PORT or TAILSCALE_HOSTNAME, also update the
#       bookmark URLs in homepage/services.yaml to match.

# ---------------------------------------------------------------------------
# Tailscale — VPN / mesh networking
# ---------------------------------------------------------------------------
TS_AUTHKEY=tskey-auth-<your-tailscale-auth-key>
# TAILSCALE_HOSTNAME=trustnas
# TAILSCALE_STATE_PATH=./docker-data/tailscale
# TAILSCALE_HTTPS_PORT=8334

# ---------------------------------------------------------------------------
# Homepage — dashboard UI
# ---------------------------------------------------------------------------
# HOMEPAGE_PORT=3000
# HOMEPAGE_LOGS_PATH=./docker-data/homepage/logs
# HOMEPAGE_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Nginx — reverse proxy
# ---------------------------------------------------------------------------
# NGINX_GARAGE_PORT=63779
# NGINX_LOGS_PATH=./docker-data/nginx_logs
# NGINX_BANDWIDTH_LIMIT=6250k
# NGINX_WORKER_CONNECTIONS=1024
# NGINX_CLIENT_MAX_BODY_SIZE=0

# ---------------------------------------------------------------------------
# Garage — S3-compatible storage
# ---------------------------------------------------------------------------
# GARAGE_RPC_SECRET=<generate with: openssl rand -hex 32>
# GARAGE_S3_PORT=3900           (127.0.0.1 only — not exposed to network)
# GARAGE_DATA_PATH=/srv/dev-disk-by-uuid-81aeb123-75b6-4659-9e3a-172bc10b62cd/trustnas-test
# GARAGE_CONFIG_PATH=./docker-data/garage/config
# GARAGE_DEFAULT_QUOTA=500MB  (default bucket quota; set to 0 for unlimited)

# ---------------------------------------------------------------------------
# Filestash — web file manager
# ---------------------------------------------------------------------------
# FILESTASH_PORT=8378            (port exposed via Tailscale)
# FILESTASH_STATE_PATH=./docker-data/filestash

# ---------------------------------------------------------------------------
# Dozzle — Docker log viewer
# ---------------------------------------------------------------------------
# DOZZLE_PORT=8379
# DOZZLE_DATA_PATH=./docker-data/dozzle

# ---------------------------------------------------------------------------
# Script defaults — used by scripts/ helper tools
# ---------------------------------------------------------------------------
# S3_ENDPOINT=http://localhost:63779
# S3_REGION=us-east-1
# S3_BENCH_BUCKET=test1
